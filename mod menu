    '.bmm-btn:hover{background:rgba(124,58,237,.18);border-color:' + ACCENT + ';color:#fff;}',
    '.bmm-btn.on{background:rgba(34,197,94,.12);border-color:#22c55e;color:#4ade80;}',
    '.bmm-btn.danger:hover{background:rgba(239,68,68,.12);border-color:#ef4444;color:#f87171;}',
    '.bmm-icon{font-size:13px;width:15px;text-align:center;flex-shrink:0;}',
    '.bmm-row{display:flex;gap:5px;margin-bottom:5px;}.bmm-row .bmm-btn{margin-bottom:0;}',
    '.bmm-input{width:100%;padding:8px 10px;background:' + PANEL + ';border:1px solid ' + BORDER + ';',
      'border-radius:7px;color:' + TEXT + ';font-size:11px;font-family:inherit;outline:none;',
      'transition:border .2s;margin-bottom:5px;}',
    '.bmm-input:focus{border-color:' + ACCENT + ';}',
    '.bmm-sep{border:none;border-top:1px solid ' + BORDER + ';margin:9px 0;}',
