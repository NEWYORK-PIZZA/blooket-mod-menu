      'transition:all .2s;border-bottom:2px solid transparent;font-family:inherit;}',
    '.bmm-tab:hover{color:' + TEXT + ';}',
    '.bmm-tab.active{color:' + ACCENT2 + ';border-bottom-color:' + ACCENT + ';}',
