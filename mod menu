    '.bmm-label{color:' + MUTED + ';font-size:9px;letter-spacing:1.8px;text-transform:uppercase;margin:0 0 7px;}',
    '.bmm-btn{width:100%;padding:9px 11px;margin-bottom:5px;background:' + PANEL + ';',
