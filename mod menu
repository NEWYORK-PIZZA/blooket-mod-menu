    '.bmm-note{font-size:10px;color:' + MUTED + ';margin:0 0 7px;line-height:1.5;}',
  ].join('');
  document.head.appendChild(style);

  var menu = document.createElement('div');
  menu.id = 'blooket-mod-menu';
  menu.innerHTML = '<div id="bmm-header">' +
      '<div><span id="bmm-title">⬡ Blooket Mod</span><span id="bmm-version">v3.0</span></div>' +
      '<button id="bmm-close" title="Close (F2)">✕</button>' +
    '</div>' +
    '<div id="bmm-tabs">' +
      '<button class="bmm-tab active" data-tab="game">Game</button>' +
      '<button class="bmm-tab" data-tab="coins">Coins</button>' +
      '<button class="bmm-tab" data-tab="misc">Misc</button>' +
    '</div>' +
    '<div id="bmm-body">' +

      // GAME TAB
      '<div class="bmm-section visible" data-section="game">' +
        '<p class="bmm-label">Answers</p>' +
        '<button class="bmm-btn" id="bmm-reveal"><span class="bmm-icon">👁</span>Reveal correct answer</button>' +
        '<button class="bmm-btn" id="bmm-auto"><span class="bmm-icon">🤖</span>Auto-answer<span class="bmm-badge">toggle</span></button>' +
        '<p class="bmm-note" style="margin-top:6px">Answer also logged to DevTools console.</p>' +
        '<hr class="bmm-sep">' +
        '<p class="bmm-label">Score / Gold</p>' +
        '<div class="bmm-row">' +
          '<button class="bmm-btn" id="bmm-s100"><span class="bmm-icon">+</span>+100</button>' +
          '<button class="bmm-btn" id="bmm-s500"><span class="bmm-icon">+</span>+500</button>' +
          '<button class="bmm-btn" id="bmm-s1k"><span class="bmm-icon">⚡</span>+1K</button>' +
        '</div>' +
      '</div>' +

      // COINS TAB
      '<div class="bmm-section" data-section="coins">' +
        '<p class="bmm-note">Tokens are stored in Firebase. This attempts to find and call Blooket\'s Firestore instance directly. Works best when logged in.</p>' +
        '<p class="bmm-label">Quick add</p>' +
        '<div class="bmm-row">' +
          '<button class="bmm-btn" id="bmm-t100"><span class="bmm-icon">🪙</span>+100</button>' +
          '<button class="bmm-btn" id="bmm-t500"><span class="bmm-icon">🪙</span>+500</button>' +
          '<button class="bmm-btn" id="bmm-t1k"><span class="bmm-icon">💰</span>+1K</button>' +
        '</div>' +
        '<hr class="bmm-sep">' +
        '<p class="bmm-label">Custom amount</p>' +
        '<input class="bmm-input" id="bmm-tok-val" type="number" placeholder="Enter amount…" min="1">' +
        '<button class="bmm-btn" id="bmm-tok-add"><span class="bmm-icon">✚</span>Add tokens</button>' +
        '<hr class="bmm-sep">' +
        '<p class="bmm-label">Cosmetics</p>' +
        '<button class="bmm-btn" id="bmm-blooks"><span class="bmm-icon">🐟</span>Unlock blooks (visual only)</button>' +
      '</div>' +

      // MISC TAB
      '<div class="bmm-section" data-section="misc">' +
        '<p class="bmm-label">Utilities</p>' +
        '<button class="bmm-btn" id="bmm-flood"><span class="bmm-icon">🛡</span>Flood protection<span class="bmm-badge">toggle</span></button>' +
        '<button class="bmm-btn" id="bmm-zoom"><span class="bmm-icon">🔍</span>Cycle zoom (100→130%)</button>' +
        '<button class="bmm-btn" id="bmm-nochat"><span class="bmm-icon">🔇</span>Hide chat</button>' +
        '<hr class="bmm-sep">' +
        '<p class="bmm-label">Debug</p>' +
        '<button class="bmm-btn" id="bmm-dump"><span class="bmm-icon">📋</span>Dump game state → console</button>' +
        '<button class="bmm-btn danger" id="bmm-reset"><span class="bmm-icon">🗑</span>Remove mod menu</button>' +
      '</div>' +

    '</div>';

  document.body.appendChild(menu);

  // ─── Tabs ─────────────────────────────────────────────────────────────────
  menu.querySelectorAll('.bmm-tab').forEach(function (tab) {
    tab.addEventListener('click', function () {
      menu.querySelectorAll('.bmm-tab').forEach(function (t) { t.classList.remove('active'); });
      menu.querySelectorAll('.bmm-section').forEach(function (s) { s.classList.remove('visible'); });
      tab.classList.add('active');
      menu.querySelector('[data-section="' + tab.dataset.tab + '"]').classList.add('visible');
    });
  });

  // ─── Drag ────────────────────────────────────────────────────────────────
  var hdr = document.getElementById('bmm-header');
  var dragging = false, ox = 0, oy = 0;
  hdr.addEventListener('mousedown', function (e) {
    dragging = true;
    var r = menu.getBoundingClientRect();
    ox = e.clientX - r.left;
    oy = e.clientY - r.top;
  });
  document.addEventListener('mousemove', function (e) {
    if (!dragging) return;
    menu.style.right = 'auto';
    menu.style.left = (e.clientX - ox) + 'px';
    menu.style.top  = (e.clientY - oy) + 'px';
  });
  document.addEventListener('mouseup', function () { dragging = false; });

  // ─── Button wiring ────────────────────────────────────────────────────────
  document.getElementById('bmm-close').onclick = function () {
    menu.style.display = 'none';
  };

  // Game tab
  document.getElementById('bmm-reveal').onclick = revealAnswers;

  var autoBtn = document.getElementById('bmm-auto');
  autoBtn.onclick = function () {
    if (autoObserver) {
      stopAutoAnswer();
      autoBtn.classList.remove('on');
    } else {
      startAutoAnswer();
      autoBtn.classList.add('on');
    }
  };

  document.getElementById('bmm-s100').onclick = function () { boostScore(100); };
  document.getElementById('bmm-s500').onclick = function () { boostScore(500); };
  document.getElementById('bmm-s1k').onclick  = function () { boostScore(1000); };

  // Coins tab
  document.getElementById('bmm-t100').onclick = function () { addTokens(100); };
  document.getElementById('bmm-t500').onclick = function () { addTokens(500); };
  document.getElementById('bmm-t1k').onclick  = function () { addTokens(1000); };
  document.getElementById('bmm-tok-add').onclick = function () {
    var v = parseInt(document.getElementById('bmm-tok-val').value, 10);
    if (!v || v < 1) { notify('Enter a valid amount', '#d97706'); return; }
    addTokens(v);
  };
  document.getElementById('bmm-blooks').onclick = unlockAllBlooks;

  // Misc tab
  var floodBtn = document.getElementById('bmm-flood');
  floodBtn.onclick = function () {
    var on = toggleFloodProtect();
    floodBtn.classList.toggle('on', on);
  };

  document.getElementById('bmm-zoom').onclick = cycleZoom;

  document.getElementById('bmm-nochat').onclick = function () {
    var chat = document.querySelector('[class*="chat"], [class*="Chat"], [class*="message"]');
    if (chat) { chat.style.display = 'none'; notify('🔇 Chat hidden', '#059669'); }
    else notify('Chat element not found', '#d97706');
  };

  document.getElementById('bmm-dump').onclick = dumpState;

  document.getElementById('bmm-reset').onclick = function () {
    if (autoObserver) { autoObserver.disconnect(); autoObserver = null; }
    if (origFetchForFlood) window.fetch = origFetchForFlood;
    document.body.style.zoom = '';
    style.remove();
    menu.remove();
  };

  // ─── F2 toggle ────────────────────────────────────────────────────────────
  document.addEventListener('keydown', function (e) {
    if (e.key === 'F2') {
      menu.style.display = menu.style.display === 'none' ? '' : 'none';
    }
  });

  notify('⬡ Blooket Mod v3.0 loaded — F2 to toggle', ACCENT);

})();
