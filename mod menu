    '#bmm-close:hover{color:#ef4444;}',
    '#bmm-tabs{display:flex;background:' + PANEL + ';border-bottom:1px solid ' + BORDER + ';}',
    '.bmm-tab{flex:1;padding:8px 2px;background:none;border:none;color:' + MUTED + ';',
