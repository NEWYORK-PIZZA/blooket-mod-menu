  var style = document.createElement('style');
  style.textContent = [
    '#blooket-mod-menu *{box-sizing:border-box;font-family:"JetBrains Mono","Fira Code",monospace;}',
    '#blooket-mod-menu{position:fixed;top:55px;right:18px;z-index:2147483647;width:310px;',
      'background:' + BG + ';border:1px solid ' + BORDER + ';border-radius:13px;overflow:hidden;',
      'box-shadow:0 20px 60px rgba(0,0,0,.65),0 0 0 1px rgba(124,58,237,.18);}',
    '#bmm-header{background:' + PANEL + ';padding:11px 15px;display:flex;align-items:center;',
      'justify-content:space-between;cursor:move;border-bottom:1px solid ' + BORDER + ';}',
    '#bmm-title{color:' + ACCENT2 + ';font-size:11px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;}',
    '#bmm-version{font-size:9px;color:' + MUTED + ';margin-left:8px;}',
